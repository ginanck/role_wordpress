{#- jinja2: lstrip_blocks: true, trim_blocks: true -#}
; {{ ansible_managed }}

[wordpress]
user = {{ wordpress_owner }}
group = {{ wordpress_group }}

listen = {{ wordpress_php_fpm_sock_dir }}/wordpress.sock
listen.owner = {{ wordpress_owner }}
listen.group = {{ wordpress_group }}
listen.mode = 0660

pm = dynamic
pm.max_children = 10
pm.start_servers = 3
pm.min_spare_servers = 2
pm.max_spare_servers = 5
pm.max_requests = 500

php_admin_value[upload_max_filesize] = 64M
php_admin_value[post_max_size] = 64M
php_admin_value[max_execution_time] = 300
php_admin_value[memory_limit] = {{ wordpress_memory_limit }}
php_admin_value[max_input_vars] = 3000

php_admin_flag[display_errors] = off
php_admin_flag[log_errors] = on
php_admin_value[error_log] = {{ wordpress_php_fpm_log_dir }}/wordpress-error.log

security.limit_extensions = .php
